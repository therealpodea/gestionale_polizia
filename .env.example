# ── Discord OAuth ──────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=IL_TUO_CLIENT_ID
DISCORD_CLIENT_SECRET=IL_TUO_CLIENT_SECRET
DISCORD_BOT_TOKEN=IL_TUO_BOT_TOKEN
DISCORD_GUILD_ID=ID_DEL_TUO_SERVER

# URL callback — su Railway: https://tuo-progetto.up.railway.app/auth/callback
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://utente:password@cluster.mongodb.net
MONGODB_DB_NAME=gestionale_polizia

# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-questa-stringa-con-qualcosa-di-lungo-e-random
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Ruoli Discord (ID numerici del tuo server) ─────────────────────────────────
# Puoi trovare gli ID abilitando la modalità sviluppatore in Discord
# (Impostazioni → Avanzate → Modalità sviluppatore), poi tasto destro sul ruolo
ROLE_STAFF=ID_RUOLO_STAFF
ROLE_DIRIGENZA=ID_RUOLO_DIRIGENZA
ROLE_ISPETTORATO=ID_RUOLO_ISPETTORATO
ROLE_SOVRINTENDENZA=ID_RUOLO_SOVRINTENDENZA
ROLE_AGENTE=ID_RUOLO_AGENTE

# ── Canali Discord (ID numerici) ───────────────────────────────────────────────
CITTADINO_ROLE_ID=ID_RUOLO_CITTADINO
WELCOME_CHANNEL_ID=ID_CANALE_BENVENUTO
CANALE_LOG_ID=ID_CANALE_LOG_BOT
CANALE_ANNUNCI_ID=ID_CANALE_ANNUNCI

# ── API Esterna (opzionale) ────────────────────────────────────────────────────
# Chiave per accedere alle API da sistemi esterni (es. altro gestionale)
API_KEY=chiave-api-segreta
POLIZIA_URL=
POLIZIA_API_KEY=

# ── Ruoli Affari Interni (ID numerici) ─────────────────────────────────────────
# NOTA: il sistema rileva i ruoli AI anche dal nome (senza emoji)
# quindi questi env sono opzionali se il bot token è configurato.
# Se vuoi usarli come fallback, inserisci gli ID:
ROLE_RESP_AI=ID_RUOLO_RESPONSABILE_REPARTO_AFFARI_INTERNI
ROLE_DIR_AI=ID_RUOLO_DIRETTORE_AFFARI_INTERNI
ROLE_AI=ID_RUOLO_AFFARI_INTERNI
ROLE_AI_PROVA=ID_RUOLO_AFFARI_INTERNI_IN_PROVA

# ── Candidature Discord ────────────────────────────────────────────────────────
CANALE_CANDIDATURE_ID=ID_CANALE_DOVE_ARRIVANO_LE_CANDIDATURE
