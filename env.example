# ═══════════════════════════════════════════════════════
# GESTIONALE POLIZIA D'ESTOVIA - Configurazione
# ═══════════════════════════════════════════════════════

# ─── SICUREZZA ──────────────────────────────────────────
# Chiave API per proteggere gli endpoint
# IMPORTANTE: Cambia questo valore con una chiave sicura!
GESTIONALE_API_KEY=estovia2026

# ─── DATABASE ───────────────────────────────────────────
# Railway fornisce automaticamente DATABASE_URL
# Non è necessario configurarlo manualmente
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Path del database SQLite (fallback se PostgreSQL non disponibile)
DB_PATH=gestionale.db

# ─── DISCORD OAUTH (Obbligatorio per login) ─────────────
# Per abilitare il login con Discord, crea un'app su:
# https://discord.com/developers/applications

# ID dell'applicazione Discord
DISCORD_CLIENT_ID=

# Secret dell'applicazione Discord
DISCORD_CLIENT_SECRET=

# ID del server Discord (Guild ID)
# Per trovarlo: Click destro sul server → Copia ID
DISCORD_GUILD_ID=

# URL di callback OAuth (sostituisci con il tuo dominio Railway)
DISCORD_REDIRECT_URI=https://gestionalepolizia-production.up.railway.app/auth/discord/callback

# ─── RICONOSCIMENTO RUOLI ───────────────────────────────

# OPZIONE 1: Bot Token (RACCOMANDATO per riconoscimento automatico)
# Token del bot Discord per leggere i nomi dei ruoli
# Come ottenerlo:
# 1. Discord Developer Portal → La tua App → Bot → Reset Token
# 2. Invita il bot nel server con permesso "Read Messages"
DISCORD_BOT_TOKEN=

# OPZIONE 2: Override Manuale (BACKUP)
# Discord IDs degli utenti che devono SEMPRE essere riconosciuti
# come dirigenza, separati da virgola (senza spazi)
# 
# Come trovare il Discord ID:
# 1. Attiva Modalità Sviluppatore: Impostazioni → Avanzate → Modalità Sviluppatore
# 2. Click destro sul tuo profilo → Copia ID
#
# Esempio: ADMIN_DISCORD_IDS=123456789012345678,987654321098765432
ADMIN_DISCORD_IDS=

# ═══════════════════════════════════════════════════════
# NOTE:
# - Con DISCORD_BOT_TOKEN: riconoscimento automatico tramite ruoli
# - Con ADMIN_DISCORD_IDS: riconoscimento manuale tramite ID
# - Puoi usare entrambi (bot token + ID come backup)
# - Non committare questo file con valori reali su GitHub!
# ═══════════════════════════════════════════════════════
